# Safe default for the first apply of this root:
# create rg-chatops-guard-platform-dev plus its minimal VNet/subnet foundation,
# and keep AKS off.
enable_aks = false

# Optional overrides for the platform root itself.
platform_resource_group_name = "rg-chatops-guard-platform-dev"
location                     = "westeurope"
cluster_name                 = "aks-dev-guard"
dns_prefix                   = "aks-dev-guard"
node_count                   = 1
node_vm_size                 = "Standard_D2as_v5"

# Minimal dev network slice managed by this root.
vnet_name                = "vnet-chatops-guard-dev"
vnet_address_space       = ["10.30.0.0/16"]
aks_node_subnet_name     = "snet-aks-nodes"
aks_node_subnet_prefixes = ["10.30.0.0/24"]

# First event-ingestion entry point. The topic itself is low-cost because it is
# usage based; subscriptions and consumers come later in the event pipeline.
enable_event_grid                      = true
event_grid_topic_name                  = "evgt-chatops-guard-dev"
event_grid_input_schema                = "EventGridSchema"
event_grid_public_network_access_enabled = false
event_grid_local_auth_enabled          = false

# Existing monitoring dependency looked up from the bootstrap resources.
log_analytics_workspace_name        = "log-chatops-guard-dev"
log_analytics_resource_group_name   = "rg-chatops-guard-state"

# When you are ready for the first real AKS plan/apply:
# 1. change enable_aks to true
# 2. keep the network defaults or adjust them deliberately
# 3. add your stable public IP as a /32 because this root now requires
#    api_server_authorized_ip_ranges when AKS is enabled
# 4. keep using a dedicated Entra admin group object ID, not a personal user
#    object ID, so AKS admin access stays transferable and reviewable
#
# Cost note:
# - B-series looks cheap but is not supported for AKS system node pools.
# - A2_v2 is cheaper than D2as_v5, but it leaves much less memory headroom for
#   a one-node demo cluster that also runs system components, monitoring, and policy addons.
# - D2as_v5 is the current best-ROI default for this repo's demo path.
#
# enable_aks = true
# api_server_authorized_ip_ranges = [
#   "203.0.113.10/32",
# ]
# entra_admin_group_object_ids = [
#   "00000000-0000-0000-0000-000000000000",
# ]
